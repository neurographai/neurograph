# ============================================================
# NeuroGraph Environment Configuration
# Copy this file to .env and modify as needed
# ============================================================

# ─────────────────────────────────────
# Core Settings
# ─────────────────────────────────────
NEUROGRAPH_STORAGE=embedded          # embedded | memory | neo4j | falkordb | kuzu
NEUROGRAPH_DATA_DIR=~/.neurograph/data
NEUROGRAPH_LOG_LEVEL=info            # trace | debug | info | warn | error
NEUROGRAPH_API_PORT=8000
NEUROGRAPH_DASHBOARD_PORT=3000

# ─────────────────────────────────────
# LLM Provider (all optional — works offline without these)
# ─────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# OLLAMA_HOST=http://localhost:11434

# Example configuring a custom endpoint for OpenAI-compatible services
# OPENAI_BASE_URL=http://localhost:11434/v1

# ─────────────────────────────────────
# Embedding Providers (19 models, 7 providers supported)
# All optional — defaults to hash embeddings (offline, free)
# ─────────────────────────────────────
# GEMINI_API_KEY=...                   # Gemini Embedding 2 Preview, text-embedding-004
# COHERE_API_KEY=...                   # Cohere embed-v4.0
# VOYAGE_API_KEY=...                   # Voyage 3/4 Large, Voyage 4 Lite
# JINA_API_KEY=...                     # Jina v3, v4
# MISTRAL_API_KEY=...                  # Mistral embed
# AZURE_OPENAI_API_KEY=...             # Azure OpenAI embeddings

# Or load providers from a TOML config file:
# NEUROGRAPH_EMBEDDING_CONFIG=neurograph.toml

# ─────────────────────────────────────
# Neo4j (only if NEUROGRAPH_STORAGE=neo4j)
# ─────────────────────────────────────
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# ─────────────────────────────────────
# FalkorDB (only if NEUROGRAPH_STORAGE=falkordb)
# ─────────────────────────────────────
# FALKORDB_HOST=localhost
# FALKORDB_PORT=6379

# ─────────────────────────────────────
# Performance Tuning
# ─────────────────────────────────────
NEUROGRAPH_SEMAPHORE_LIMIT=10        # Max concurrent LLM calls
NEUROGRAPH_CACHE_SIZE_MB=256         # In-memory cache size

# ─────────────────────────────────────
# Observability
# ─────────────────────────────────────
# RUST_LOG=info,neurograph=debug
# OTLP_ENDPOINT=http://localhost:4317

# ─────────────────────────────────────
# Telemetry (anonymous usage stats)
# ─────────────────────────────────────
NEUROGRAPH_TELEMETRY_ENABLED=true    # Set to false to disable
