# NeuroGraph Environment configuration

# API Keys (For LLM and Embeddings - Only needed if cloud providers are used)
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# GEMINI_API_KEY="..."

# Example configuring a custom endpoint for OpenAI-compatible services (vLLM, Ollama, LM Studio)
# OPENAI_BASE_URL="http://localhost:11434/v1"

# Telemetry
# RUST_LOG="info,neurograph=debug"
# OTLP_ENDPOINT="http://localhost:4317"

# Database Configuration (Optional if not using Sled default)
# NEO4J_URI="bolt://localhost:7687"
# NEO4J_USER="neo4j"
# NEO4J_PASS="password"
